{
  "manifest_version": 2,
  "name": "LogFizz – Time Tracker",
  "version": "1.0.0",
  "description": "Quick access to your LogFizz time tracking buttons. Start and stop timers, or open the app in a new tab.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "LogFizz – Time Tracker"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "storage",
    "tabs",
    "https://*.logfizz.magnusso.nz/*",
    "https://*.logfizz.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "logfizz@magnusso.nz",
      "strict_min_version": "109.0"
    }
  }
}

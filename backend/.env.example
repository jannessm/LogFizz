APP_URL=http://localhost:5173
# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=clock_user
DB_PASSWORD=clock_password
DB_DATABASE=clock_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=clock_redis_password

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
ADMIN_EMAIL=admin@example.com

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Session Configuration
SESSION_SECRET=change-this-secret-in-production-to-a-very-secure-value

# Application Configuration
NODE_ENV=development

# hCaptcha Configuration (optional - for bot protection)
# Get your keys from https://www.hcaptcha.com/
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# Stripe Configuration (for payments)
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Admin Configuration
# Password to protect admin endpoints like toggle-paywall
ADMIN_PASSWORD=change-this-admin-password-in-production
